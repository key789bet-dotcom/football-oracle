# Sao chép file này thành .env và điền key thật của bạn

# Nguồn dữ liệu trận: footballdata (khuyên dùng) | sofascore | apifootball
DATA_PROVIDER=footballdata

# --- football-data.org (đăng ký free, có token qua email) ---
FOOTBALLDATA_TOKEN=dan_token_cua_ban

# --- KÈO THẬT (tùy chọn): the-odds-api.com, free 500 request/tháng ---
# Đăng ký: https://the-odds-api.com/  -> để trống nếu chưa dùng (tool vẫn chạy bằng model)
ODDS_API_KEY=
ODDS_TTL=600

# --- Nếu dùng API-Football / SofaScore (RapidAPI) ---
RAPIDAPI_KEY=
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com
SOFA_HOST=sofascore.p.rapidapi.com

# Bộ nhớ đệm (giây)
CACHE_TTL=60
